{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User statistics and progress tracking.",
      "type": "object",
      "properties": {
        "xp": { "type": "integer" },
        "level": { "type": "integer" },
        "streak": { "type": "integer" },
        "lastActiveDate": { "type": "string", "format": "date" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "completedCount": { "type": "integer" },
        "categories": {
          "type": "object",
          "properties": {
            "logic": { "type": "integer" },
            "observation": { "type": "integer" },
            "strategy": { "type": "integer" },
            "discipline": { "type": "integer" }
          },
          "required": ["logic", "observation", "strategy", "discipline"]
        },
        "chessUsername": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["xp", "level", "streak", "lastActiveDate", "badges", "completedCount", "categories", "updatedAt"]
    },
    "Mission": {
      "title": "Mission Record",
      "description": "A daily mission instance for a specific user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "timeRange": { "type": "string" },
        "durationMinutes": { "type": "integer" },
        "category": { "type": "string", "enum": ["Warmup", "Analysis", "Focus", "Social", "Reflection", "Gaming"] },
        "isCompleted": { "type": "boolean" },
        "notes": { "type": "string" },
        "date": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "name", "timeRange", "durationMinutes", "category", "isCompleted", "notes", "date", "updatedAt"]
    },
    "JournalTopic": {
      "title": "Journal Topic",
      "description": "A high-level category for deductions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "name", "createdAt"]
    },
    "JournalEntry": {
      "title": "Journal Entry",
      "description": "Daily deduction log for a specific topic.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "topicId": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string" },
        "deductions": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "topicId", "userId", "date", "deductions", "updatedAt"]
    },
    "DetectiveCase": {
      "title": "Detective Case",
      "description": "An AI-simulated role-play case.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "enum": ["daily", "weekly", "monthly"] },
        "title": { "type": "string" },
        "scenario": { "type": "string" },
        "clues": { "type": "array", "items": { "type": "string" } },
        "discipline": { "enum": ["logic", "observation", "strategy", "discipline"] },
        "difficulty": { "enum": ["low", "medium", "high", "legendary"] },
        "status": { "enum": ["available", "passed", "failed", "dismissed"] },
        "xpReward": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "hiddenTruth": { "type": "string" },
        "solution": { "type": "string" },
        "evaluation": { "type": "string" },
        "score": { "type": "integer" }
      },
      "required": ["id", "userId", "type", "title", "scenario", "clues", "discipline", "difficulty", "status", "xpReward", "createdAt", "expiresAt", "hiddenTruth"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Public user profile and stats."
    },
    "users/{userId}/missions/{missionId}": {
      "schema": "Mission",
      "description": "Individual mission records for a user."
    },
    "users/{userId}/topics/{topicId}": {
      "schema": "JournalTopic",
      "description": "User journal topics."
    },
    "users/{userId}/topics/{topicId}/entries/{entryId}": {
      "schema": "JournalEntry",
      "description": "Daily entries for a specific topic."
    },
    "users/{userId}/cases/{caseId}": {
      "schema": "DetectiveCase",
      "description": "Simulated detective cases for the user."
    }
  }
}
