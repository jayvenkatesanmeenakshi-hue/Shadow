rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Identity Primitives
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // User Profile Validation
    function isValidUser(data) {
      return data.keys().hasAll(['xp', 'level', 'streak', 'lastActiveDate', 'badges', 'completedCount', 'categories', 'updatedAt'])
        && (data.keys().size() == 8 || (data.keys().size() == 9 && data.keys().hasAll(['chessUsername'])))
        && data.xp is int
        && data.level is int
        && data.streak is int
        && data.lastActiveDate is string
        && data.badges is list
        && data.completedCount is int
        && data.categories is map
        && (!data.keys().hasAny(['chessUsername']) || data.chessUsername is string)
        && data.updatedAt == request.time;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['xp', 'level', 'streak', 'lastActiveDate', 'badges', 'completedCount', 'categories', 'updatedAt', 'chessUsername'])
      );
    }

    // Mission Validation
    function isValidMission(data) {
      return data.keys().hasAll(['id', 'userId', 'name', 'timeRange', 'durationMinutes', 'category', 'isCompleted', 'notes', 'date', 'updatedAt'])
        && data.keys().size() == 10
        && isValidId(data.id)
        && data.userId == request.auth.uid
        && data.name is string && data.name.size() <= 200
        && data.timeRange is string
        && data.durationMinutes is int
        && data.category in ['Warmup', 'Analysis', 'Focus', 'Social', 'Reflection', 'Gaming']
        && data.isCompleted is bool
        && data.notes is string && data.notes.size() <= 5000
        && data.date is string
        && data.updatedAt == request.time;
    }

    match /users/{userId}/missions/{missionId} {
      allow list: if isOwner(userId) && resource.data.userId == request.auth.uid;
      allow get: if isOwner(userId) && isValidId(missionId);
      allow create: if isOwner(userId) && isValidId(missionId) && isValidMission(incoming());
      allow update: if isOwner(userId) && isValidId(missionId) && isValidMission(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['isCompleted', 'notes', 'updatedAt'])
      );
      allow delete: if isOwner(userId) && isValidId(missionId);
    }

    // Journal Validation
    function isValidTopic(data) {
      return data.keys().hasAll(['id', 'userId', 'name', 'createdAt'])
        && data.keys().size() == 4
        && isValidId(data.id)
        && data.userId == request.auth.uid
        && data.name is string && data.name.size() <= 100
        && data.createdAt == request.time;
    }

    function isValidEntry(data) {
      return data.keys().hasAll(['id', 'topicId', 'userId', 'date', 'deductions', 'updatedAt'])
        && data.keys().size() == 6
        && isValidId(data.id)
        && data.userId == request.auth.uid
        && data.date is string
        && data.deductions is string && data.deductions.size() <= 10000
        && data.updatedAt == request.time;
    }

    match /users/{userId}/topics/{topicId} {
      allow list: if isOwner(userId) && resource.data.userId == request.auth.uid;
      allow get: if isOwner(userId) && isValidId(topicId);
      allow create: if isOwner(userId) && isValidId(topicId) && isValidTopic(incoming());
      allow update: if isOwner(userId) && isValidId(topicId) && isValidTopic(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name'])
      );
      allow delete: if isOwner(userId) && isValidId(topicId);
    }

    match /users/{userId}/topics/{topicId}/entries/{entryId} {
      allow list: if isOwner(userId) && resource.data.userId == request.auth.uid;
      allow get: if isOwner(userId) && isValidId(entryId);
      allow create: if isOwner(userId) && isValidId(entryId) && isValidEntry(incoming());
      allow update: if isOwner(userId) && isValidId(entryId) && isValidEntry(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['deductions', 'updatedAt'])
      );
      allow delete: if isOwner(userId) && isValidId(entryId);
    }
  }
}
